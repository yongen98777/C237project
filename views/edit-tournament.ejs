<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Tournament - TourneyHub</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav>
        <div class="container">
            <h1>🎮 TourneyHub</h1>
            <div>
                <a href="/">Home</a>
                <a href="/tournaments">Tournaments</a>
                <a href="/dashboard">Dashboard</a>
                <a href="/auth/logout">Logout</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="form-container">
            <h1>Edit Tournament</h1>
            
            <% if (error) { %>
                <div class="alert error"><%= error %></div>
            <% } %>
            
            <form action="/tournaments/<%= tournament.id %>?_method=PUT" method="POST">
                <div class="form-group">
                    <label>Tournament Name *</label>
                    <input type="text" name="name" required value="<%= tournament.name %>">
                </div>
                <div class="form-group">
                    <label>Game *</label>
                    <input type="text" name="game" required value="<%= tournament.game %>">
                </div>
                <div class="form-group">
                    <label>Format *</label>
                    <input type="text" name="format" required value="<%= tournament.format %>">
                </div>
                <div class="form-group">
                    <label>Prize Pool ($)</label>
                    <input type="number" name="prize_pool" step="0.01" value="<%= tournament.prize_pool %>">
                </div>
                <div class="form-group">
                    <label>Max Teams</label>
                    <input type="number" name="max_teams" value="<%= tournament.max_teams %>">
                </div>
                <div class="form-group">
                    <label>Status</label>
                    <select name="status">
                        <option value="registration" <%= tournament.status === 'registration' ? 'selected' : '' %>>Registration</option>
                        <option value="ongoing" <%= tournament.status === 'ongoing' ? 'selected' : '' %>>Ongoing</option>
                        <option value="completed" <%= tournament.status === 'completed' ? 'selected' : '' %>>Completed</option>
                    </select>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Start Date</label>
                        <input type="date" name="start_date" value="<%= tournament.start_date %>">
                    </div>
                    <div class="form-group">
                        <label>End Date</label>
                        <input type="date" name="end_date" value="<%= tournament.end_date %>">
                    </div>
                </div>
                <button type="submit" class="btn">Update Tournament</button>
                <a href="/tournaments/<%= tournament.id %>" class="btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</body>
</html>